{
  "name": "@usememos/mui",
  "version": "0.1.0",
  "description": "Opinionated React UI kit with themeable CSS variables and compound APIs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/theme.css",
  "sideEffects": [
    "./dist/theme.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./theme.css": "./dist/theme.css",
    "./button": {
      "import": {
        "types": "./dist/button.d.ts",
        "default": "./dist/button.js"
      },
      "require": {
        "types": "./dist/button.d.cts",
        "default": "./dist/button.cjs"
      }
    },
    "./checkbox": {
      "import": {
        "types": "./dist/checkbox.d.ts",
        "default": "./dist/checkbox.js"
      },
      "require": {
        "types": "./dist/checkbox.d.cts",
        "default": "./dist/checkbox.cjs"
      }
    },
    "./dialog": {
      "import": {
        "types": "./dist/dialog.d.ts",
        "default": "./dist/dialog.js"
      },
      "require": {
        "types": "./dist/dialog.d.cts",
        "default": "./dist/dialog.cjs"
      }
    },
    "./dropdown-menu": {
      "import": {
        "types": "./dist/dropdown-menu.d.ts",
        "default": "./dist/dropdown-menu.js"
      },
      "require": {
        "types": "./dist/dropdown-menu.d.cts",
        "default": "./dist/dropdown-menu.cjs"
      }
    },
    "./popover": {
      "import": {
        "types": "./dist/popover.d.ts",
        "default": "./dist/popover.js"
      },
      "require": {
        "types": "./dist/popover.d.cts",
        "default": "./dist/popover.cjs"
      }
    },
    "./radio-group": {
      "import": {
        "types": "./dist/radio-group.d.ts",
        "default": "./dist/radio-group.js"
      },
      "require": {
        "types": "./dist/radio-group.d.cts",
        "default": "./dist/radio-group.cjs"
      }
    },
    "./select": {
      "import": {
        "types": "./dist/select.d.ts",
        "default": "./dist/select.js"
      },
      "require": {
        "types": "./dist/select.d.cts",
        "default": "./dist/select.cjs"
      }
    },
    "./separator": {
      "import": {
        "types": "./dist/separator.d.ts",
        "default": "./dist/separator.js"
      },
      "require": {
        "types": "./dist/separator.d.cts",
        "default": "./dist/separator.cjs"
      }
    },
    "./switch": {
      "import": {
        "types": "./dist/switch.d.ts",
        "default": "./dist/switch.js"
      },
      "require": {
        "types": "./dist/switch.d.cts",
        "default": "./dist/switch.cjs"
      }
    },
    "./tooltip": {
      "import": {
        "types": "./dist/tooltip.d.ts",
        "default": "./dist/tooltip.js"
      },
      "require": {
        "types": "./dist/tooltip.d.cts",
        "default": "./dist/tooltip.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec tsup --config tsup.config.ts && mkdir -p dist && cp ../theme/src/theme.css dist/theme.css",
    "typecheck": "tsc --noEmit",
    "check:package": "pnpm exec publint . && pnpm exec attw --pack --profile node16 --exclude-entrypoints ./theme.css ."
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "clsx": "^2.0.0",
    "lucide-react": "^0.523.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "tsup": "^8.3.5",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "theme"
  ],
  "repository": "https://github.com/usememos/mui",
  "homepage": "https://github.com/usememos/mui",
  "bugs": {
    "url": "https://github.com/usememos/mui/issues"
  },
  "license": "MIT"
}
